# Porta do servidor (default: 3000)
PORT=3000

# Chave de API para proteger os endpoints (opcional)
# API_KEY=sua-chave-secreta-aqui

# Credenciais Anthropic (para login automático)
# ANTHROPIC_EMAIL=seu-email@exemplo.com
# ANTHROPIC_PASSWORD=sua-senha-aqui

# Navegador padrão (chromium, firefox, chrome, edge)
BROWSER=chromium

# Modo servidor: usa cookies salvos sem browser interativo
SERVER_ONLY=1